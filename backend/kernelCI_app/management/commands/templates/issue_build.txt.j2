{% extends "base.txt" %}
{% block header %}{% endblock %}
{% block content -%}
New build issue found on {{ issue["tree_name"] }}/{{ issue["git_repository_branch"] }}:

---
{{ issue["comment"]}}
---
{% if "misc" in issue.keys() and "logspec" in issue["misc"].keys() %}
